{
	"name": "ivanna",
	"description": "My Website via npm hopefully",
	"version": "1.0.0",
	"private": true,
	"repository": {
		"type": "git",
		"url": "git+https://github.com/AbnormalHumanBean/crispy-memory.git"
	},
	"license": "MIT",
	"scripts": {
		"cbuild": "npm run css",
		"css-compile": "sass --style compressed --source-map --embed-sources --no-error-css --load-path=node_modules/ src/scss/:src/css/",
		"css-lint": "stylelint \"src/scss/**/*.scss\" --fix",
		"css-prefix": "postcss --replace src/css/styles.css --use autoprefixer --map",
		"css": "npm-run-all css-compile css-prefix",
		"server": "sirv --dev --no-clear --port 3000",
		"cstart": "npm-run-all --parallel watch server",
		"watch": "nodemon -e html,scss -x \"npm run css\"",
		"ctest": "npm-run-all css-lint css",
		"start": "webpack serve --no-client-overlay",
		"build": "webpack build --mode=production",
		"test": "npm run build"
	},
	"dependencies": {
		"@popperjs/core": "^2.11.8",
		"marked": "^18.0.5",
		"masonry-layout": "^4.2.2",
		"node-fetch": "^3.3.2",
		"pdfjs-viewer-element": "^3.2.2"
	},
	"devDependencies": {
		"autoprefixer": "^10.4.19",
		"bootstrap": "^5.3.3",
		"copy-webpack-plugin": "^14.0.0",
		"css-loader": "^7.1.1",
		"css-minimizer-webpack-plugin": "^8.0.0",
		"html-webpack-plugin": "^5.6.0",
		"mini-css-extract-plugin": "^2.9.0",
		"nodemon": "^3.1.0",
		"npm-run-all": "^4.1.5",
		"postcss": "^8.4.38",
		"postcss-cli": "^11.0.0",
		"sass": "^1.100.0",
		"sirv-cli": "^3.0.1",
		"stylelint": "^16.26.1",
		"stylelint-config-twbs-bootstrap": "^16.1.0",
		"webpack": "^5.107.2",
		"webpack-cli": "^7.0.3",
		"webpack-dev-server": "^5.0.4"
	},
	"main": "webpack.config.js",
	"keywords": [],
	"author": "",
	"bugs": {
		"url": "https://github.com/AbnormalHumanBean/academia/issues"
	},
	"homepage": "https://github.com/AbnormalHumanBean/academia#readme"
}
